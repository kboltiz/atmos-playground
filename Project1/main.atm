require "atmos.env.pico"

val printFoo = require "GameStates/example"

val TitleScreen = require "GameStates/TitleScreen"
val GameScreen  = require "GameStates/GameScreen"
val ScoreScreen = require "GameStates/ScoreScreen"

print(printFoo)

do {
    printFoo()
    await TitleScreen()
    loop {
        val score = await GameScreen()
        await ScoreScreen(score)
    }
}
