func (attackRate) {
    print "[Enemy (+)]"

    par {
        every @attackRate {
            print "[Enemy Attack]"

            ;; Sending damage signal to the GameScreen
            ;; and also all its children (include Player)
            emit [:global] (:player_damaged)
        }
    } with {
        ;; Enemy Draw
        every :draw {}
    }

    print "[Enemy (-)]"
}
