require "atmos.env.clock"
;; require "atmos.env.pico"

pin Player = task(func() {
    print "Player Created"

    defer {
        print "Player Died"
    }

    every :clock {
        print('Player Clock')
    }
})

val PlayerInstance = spawn Player()

par_and {
    watching PlayerInstance {
        print "e"
    }
} with {
    await @1
}

print("Script End")
